SERVER_URL=ws://localhost:8080
TUNNEL_SECRET=super_secret_token_change_me
ENABLE_SECURE_HANDSHAKE=true
ENABLE_MAX_CONNECTIONS=true
MAX_CONNECTIONS=2000
MAX_FRAME_SIZE=10485760
MAX_SOCKET_BUFFER_MB=1
MAX_HOSTNAME_SIZE=2048
BLOCK_LOCAL_NETWORK=true
ENABLE_ENCRYPTION=true
ENCRYPTION_SECRET=my_custom_aes_key_12345
