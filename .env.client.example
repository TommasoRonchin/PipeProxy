# ==========================================
# PipeProxy - CLIENT CONFIGURATION (Raspberry)
# ==========================================

# ------------------------------------------
# 1. VPS CONNECTION DETAILS
# ------------------------------------------
# SERVER_URL: The public WebSocket address of your VPS where the tunnelServer is listening.
# Format: ws://<VPS_IP>:<TUNNEL_PORT>
SERVER_URL=ws://YOUR_VPS_IP:8080

# TUNNEL_SECRET: The authentication token to establish the tunnel.
# MUST MATCH the value located in the VPS's .env.server file!
TUNNEL_SECRET=super_secret_token_change_me

# ------------------------------------------
# 2. LOCAL LIMITS
# ------------------------------------------
# ENABLE_MAX_CONNECTIONS: Prevent the local network from being overwhelmed by too many streams.
ENABLE_MAX_CONNECTIONS=true

# MAX_CONNECTIONS: Total parallel outbound TCP connections the Raspberry is allowed to open.
MAX_CONNECTIONS=2000
