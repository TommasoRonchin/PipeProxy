# ==========================================
# PipeProxy - CLIENT CONFIGURATION (Raspberry)
# ==========================================

# ------------------------------------------
# 1. VPS CONNECTION DETAILS
# ------------------------------------------
# SERVER_URL: The public WebSocket address of your VPS where the tunnelServer is listening.
# Format: ws://<VPS_IP>:<TUNNEL_PORT>
SERVER_URL=ws://YOUR_VPS_IP:8080

# TUNNEL_SECRET: The authentication token to establish the tunnel.
# MUST MATCH the value located in the VPS's .env.server file!
TUNNEL_SECRET=super_secret_token_change_me

# ENABLE_SECURE_HANDSHAKE: Secures the initial connection using a cryptographic Challenge-Response HMAC.
# Prevents replay attacks and plaintext intercept of the TUNNEL_SECRET if you are using 'ws://' instead of 'wss://'.
# Both client and server must have this set to true.
ENABLE_SECURE_HANDSHAKE=true

# ------------------------------------------
# 2. LOCAL LIMITS
# ------------------------------------------
# ENABLE_MAX_CONNECTIONS: Prevent the local network from being overwhelmed by too many streams.
ENABLE_MAX_CONNECTIONS=true

# MAX_CONNECTIONS: Total parallel outbound TCP connections the Raspberry is allowed to open.
MAX_CONNECTIONS=2000

# MAX_FRAME_SIZE: The maximum allowed size for a single multiplexed frame (in bytes).
# Prevents Out-Of-Memory (OOM) Denial of Service attacks from malicious frame headers. (Default: 10485760 = 10MB)
MAX_FRAME_SIZE=10485760

# MAX_SOCKET_BUFFER_MB: Maximum buffer limit (in MB) for outbound connections before destroying the socket.
# Protects the device (e.g., Raspberry Pi) from OOM freezes on slow internet / heavy traffic downloads. (Default: 1)
MAX_SOCKET_BUFFER_MB=1

# BLOCK_LOCAL_NETWORK: Prevents SSRF attacks by preventing the proxy from connecting to private/local IP addresses.
# Ensures users of the proxy cannot access the client's home/company network. (Default: true)
BLOCK_LOCAL_NETWORK=true

# ------------------------------------------
# 3. CUSTOM TUNNEL ENCRYPTION (Zero-Dependency)
# ------------------------------------------
# ENABLE_ENCRYPTION: Cripta l'intero flusso prima di inviarlo al WebSocket usando AES-256-CTR.
ENABLE_ENCRYPTION=true

# ENCRYPTION_SECRET: Password per il cifratore. Deve combaciare con quella del server!
ENCRYPTION_SECRET=change_me_to_a_long_random_string_for_aes
