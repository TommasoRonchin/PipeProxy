# ==========================================
# PipeProxy - SERVER CONFIGURATION (VPS)
# ==========================================

# ------------------------------------------
# 1. NETWORK & TUNNEL SETTINGS
# ------------------------------------------
# PORT: The public port where users will connect to use the Proxy (Default: 3128)
PORT=3128

# TUNNEL_PORT: The internal port the WebSocket tunnel uses. The Raspberry Pi must connect here.
TUNNEL_PORT=8080

# TUNNEL_SECRET: A strong password to prevent rogue devices from impersonating your Raspberry Pi.
# MUST MATCH the secret on the client!
TUNNEL_SECRET=super_secret_token_change_me

# ENABLE_SECURE_HANDSHAKE: Secures the initial connection using a cryptographic Challenge-Response HMAC.
# Prevents replay attacks and plaintext intercept of the TUNNEL_SECRET if you are using 'ws://' instead of 'wss://'.
# Both client and server must have this set to true.
ENABLE_SECURE_HANDSHAKE=true

# HANDSHAKE_TIMEOUT_MS: Allowed clock drift (in milliseconds) between client and server for handshakes. (Default: 300000 = 5 min)
HANDSHAKE_TIMEOUT_MS=300000

# MAX_NONCE_TRACKING_SIZE: Maximum number of used nonces to track in memory for replay protection.
# This prevents DoS attacks from filling the server's RAM with unique handshake nonces. (Default: 100000)
MAX_NONCE_TRACKING_SIZE=100000

# RATE_LIMIT_MS: Wait time required between new tunnel connections from the Raspberry Pi to prevent connection flapping DoS.
# (Default: 1000 ms)
RATE_LIMIT_MS=1000


# ------------------------------------------
# 2. PROXY AUTHENTICATION (Security)
# ------------------------------------------
# ENABLE_PROXY_AUTH: Require users to send a username/password to use the proxy.
# HIGHLY RECOMMENDED if the VPS proxy port is exposed to the public internet!
ENABLE_PROXY_AUTH=true

# Credentials used by clients (e.g., curl -U admin:securepassword123 ...)
PROXY_AUTH_USERNAME=admin
PROXY_AUTH_PASSWORD=securepassword123

# ENABLE_TLS_PROXY: Wraps the Proxy TCP socket in a secure TLS layer (HTTPS Proxy).
# Strongly recommended if Proxy Auth is enabled over the internet, to prevent credential sniffing.
# Requires valid certificates.
ENABLE_TLS_PROXY=false
# TLS_CERT_PATH=/etc/letsencrypt/live/proxy.yourdomain.com/fullchain.pem
# TLS_KEY_PATH=/etc/letsencrypt/live/proxy.yourdomain.com/privkey.pem


# ------------------------------------------
# 3. PERFORMANCE & LIMITS
# ------------------------------------------
# ENABLE_MAX_CONNECTIONS: Whether to enforce a hard cap on concurrent streams in the tunnel.
ENABLE_MAX_CONNECTIONS=true

# MAX_CONNECTIONS: The absolute maximum number of parallel connections the proxy will accept.
# Prevents Memory Leaks and DDoS attacks.
MAX_CONNECTIONS=2000

# MAX_SOCKET_BUFFER_MB: Maximum buffer limit (in MB) for outbound connections on the proxy side.
# Protects the server from Out-Of-Memory (OOM) freezes on slow target responses. (Default: 1)
MAX_SOCKET_BUFFER_MB=1

# MAX_FRAME_SIZE: The maximum allowed size for a single multiplexed frame (in bytes).
# Prevents Out-Of-Memory (OOM) Denial of Service attacks from malicious frame headers. (Default: 10485760 = 10MB)
MAX_FRAME_SIZE=10485760

# MAX_PROXY_HEADER_SIZE: Maximum allowed HTTP header size for proxy clients.
# Protects against Slowloris Memory Exhaustion attacks on the public proxy port. (Default: 8192 Bytes)
MAX_PROXY_HEADER_SIZE=8192

# MAX_PROXY_TIMEOUT_MS: Maximum time in milliseconds to wait for a proxy client to send its HTTP headers.
# Protects against Slowloris Connection Exhaustion attacks. (Default: 10000 ms)
MAX_PROXY_TIMEOUT_MS=10000

# IDLE_TIMEOUT_MS: Maximum time in milliseconds to keep a proxy/tunnel socket alive if no data is sent/received.
# Protects against Slowloris DoS attacks that parse headers but keep connections hanging. (Default: 60000 ms)
IDLE_TIMEOUT_MS=60000

# REWRITE_PROXY_URLS: Rewrites absolute URLs in HTTP requests to absolute paths for better target compatibility. (Default: true)
REWRITE_PROXY_URLS=true

# ------------------------------------------
# 4. CUSTOM TUNNEL ENCRYPTION (Zero-Dependency)
# ------------------------------------------
# ENABLE_ENCRYPTION: Encrypts the entire WebSocket network stream using native AES-256-GCM in NodeJS.
# Set it to "true" if you use plain ws:// without Nginx and want to prevent eavesdropping.
ENABLE_ENCRYPTION=true

# ENCRYPTION_SECRET: A very long string that serves as a password for the AES cipher.
# MUST be identical on both client and server!
ENCRYPTION_SECRET=change_me_to_a_long_random_string_for_aes

# STRICT_SEQUENCE_CHECK: Rejects packets that arrive out of order or with gaps. (Default: true)
# Provides the strongest protection against replay and packet dropping attacks.
STRICT_SEQUENCE_CHECK=true
