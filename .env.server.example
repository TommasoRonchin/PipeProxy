# ==========================================
# PipeProxy - SERVER CONFIGURATION (VPS)
# ==========================================

# ------------------------------------------
# 1. NETWORK & TUNNEL SETTINGS
# ------------------------------------------
# PORT: The public port where users will connect to use the Proxy (Default: 3128)
PORT=3128

# TUNNEL_PORT: The internal port the WebSocket tunnel uses. The Raspberry Pi must connect here.
TUNNEL_PORT=8080

# TUNNEL_SECRET: A strong password to prevent rogue devices from impersonating your Raspberry Pi.
# MUST MATCH the secret on the client!
TUNNEL_SECRET=super_secret_token_change_me


# ------------------------------------------
# 2. PROXY AUTHENTICATION (Security)
# ------------------------------------------
# ENABLE_PROXY_AUTH: Require users to send a username/password to use the proxy.
# HIGHLY RECOMMENDED if the VPS proxy port is exposed to the public internet!
ENABLE_PROXY_AUTH=true

# Credentials used by clients (e.g., curl -U admin:securepassword123 ...)
PROXY_AUTH_USERNAME=admin
PROXY_AUTH_PASSWORD=securepassword123


# ------------------------------------------
# 3. PERFORMANCE & LIMITS
# ------------------------------------------
# ENABLE_MAX_CONNECTIONS: Whether to enforce a hard cap on concurrent streams in the tunnel.
ENABLE_MAX_CONNECTIONS=true

# MAX_CONNECTIONS: The absolute maximum number of parallel connections the proxy will accept.
# Prevents Memory Leaks and DDoS attacks.
MAX_CONNECTIONS=2000

# ------------------------------------------
# 4. CUSTOM TUNNEL ENCRYPTION (Zero-Dependency)
# ------------------------------------------
# ENABLE_ENCRYPTION: Cripta l'intero flusso di rete WebSocket usando AES-256-CTR nativo in NodeJS.
# Impostalo su "true" se usi ws:// in chiaro senza Nginx e vuoi evitare intercettazioni.
ENABLE_ENCRYPTION=true

# ENCRYPTION_SECRET: Una stringa lunghissima che fa da password per il cifratore AES.
# DEVE essere identica nel client e nel server!
ENCRYPTION_SECRET=change_me_to_a_long_random_string_for_aes
